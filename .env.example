# Example environment configuration for Production to Development Data Anonymizer
# Copy this file to .env and fill in your actual values

# SQL Server Connection Strings
PROD_SQL_CONNECTION="DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-prod-server.database.windows.net;DATABASE={db};UID=your-username;PWD=your-password;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;"
DEV_SQL_CONNECTION="DRIVER={ODBC Driver 17 for SQL Server};SERVER=your-dev-server.database.windows.net;DATABASE={db};UID=your-username;PWD=your-password;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;"

# Presidio Service URLs
PRESIDIO_ANALYZER_URL="https://your-presidio-analyzer.azurewebsites.net"
PRESIDIO_ANONYMIZER_URL="https://your-presidio-anonymizer.azurewebsites.net"

# Optional: Azure Storage for file handling
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=yourkey;EndpointSuffix=core.windows.net"

# Logging
LOG_LEVEL="INFO"

# Azure Deployment Variables (for deploy.sh)
AZURE_SUBSCRIPTION_ID="your-subscription-id"
RESOURCE_GROUP_NAME="prod-to-dev-anonymizer-rg"
LOCATION="eastus"
ENVIRONMENT="dev"
DEPLOY_PRESIDIO="false"
